#!/bin/bash

UNMAP_CLASSES=(
    "YandexMusic"
    "Steam"
)

current_class=$(hyprctl activewindow -j | jq -r ".class")

for class in "${UNMAP_CLASSES[@]}"; do
    if [ "$current_class" = "$class" ]; then
    hyprctl dispatch movetoworkspacesilent "special:hidden"
        exit 0
    fi
done

hyprctl dispatch killactive ""
